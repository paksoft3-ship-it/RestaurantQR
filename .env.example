# ---- Public (safe to expose) ----
NEXT_PUBLIC_APP_NAME=YourPlatform
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,tr,ar

# Business values — leave blank until verified (UI shows "To be confirmed").
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_WORKING_HOURS=
NEXT_PUBLIC_LEGAL_COMPANY_NAME=
NEXT_PUBLIC_PRIVACY_CONTACT=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_LINKEDIN=

# ---- Database ----
# When set, the app reads/writes a real Postgres database (Drizzle ORM).
# When blank, it falls back to in-memory seed data (demo mode).
# Local dev (Docker):   postgres://yourplatform:yourplatform@localhost:5432/yourplatform
# Vercel:               use a Neon/Vercel Postgres pooled connection string.
DATABASE_URL=

# ---- Server-only secrets (NEVER commit real values) ----
# Strong random string signing the admin session cookie. REQUIRED for real auth.
# Generate: openssl rand -base64 32
AUTH_SECRET=dev-insecure-secret-change-me

# Auth mode: "real" verifies per-user scrypt password hashes in the database
# (requires DATABASE_URL + AUTH_SECRET). Anything else = mock/demo auth.
AUTH_MODE=mock
# Used only by `pnpm db:seed`: if set, seeds the admin user's login password
# (real auth). Leave blank and use `pnpm auth:set-password <email> <pw>` instead.
SEED_ADMIN_PASSWORD=

# Enables mock admin auth in development (ignored when AUTH_MODE=real).
ENABLE_MOCK_AUTH=true
# DEMO ONLY: explicitly allow mock admin auth on a PRODUCTION deployment (e.g.
# Vercel). Leave false for real deployments. When true, the admin login works
# with the mock credentials below.
ALLOW_MOCK_AUTH_IN_PRODUCTION=false
MOCK_ADMIN_EMAIL=admin@yourplatform.test
MOCK_ADMIN_PASSWORD=demo1234

# mock | configured
FORM_TRANSPORT=mock
# off | mock | configured
ANALYTICS_MODE=mock

# ---- PDF Menu Import (feature) ----
NEXT_PUBLIC_MENU_PDF_IMPORT=true
NEXT_PUBLIC_MENU_IMPORT_MAX_FILE_SIZE_MB=25
NEXT_PUBLIC_MENU_IMPORT_MAX_PAGE_COUNT=40
NEXT_PUBLIC_MENU_IMPORT_MAX_IMAGE_COUNT=200
NEXT_PUBLIC_MENU_IMPORT_CONFIDENCE_HIGH=0.9
NEXT_PUBLIC_MENU_IMPORT_CONFIDENCE_MEDIUM=0.7
# Server-only (worker + AI). Leave blank in the demo (deterministic extractor is used).
MENU_IMPORT_WORKER_URL=
MENU_IMPORT_WORKER_SECRET=
MENU_IMPORT_QUEUE_URL=
MENU_IMPORT_STORAGE_BUCKET=
MENU_IMPORT_TEMP_RETENTION_HOURS=72
MENU_IMPORT_JOB_TIMEOUT_SECONDS=900
MENU_IMPORT_PAGE_TIMEOUT_SECONDS=120
MENU_IMPORT_OCR_LANGUAGES=tur,eng,ara
MENU_IMPORT_AI_ENABLED=false
MENU_IMPORT_AI_PROVIDER=
MENU_IMPORT_AI_MODEL=
MENU_IMPORT_AI_MAX_PAGES=10
